<Application x:Class="Wpeek.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Shared palette -->
        <SolidColorBrush x:Key="PillBg"      Color="#F01E1E21"/>
        <SolidColorBrush x:Key="PillBorder"  Color="#18FFFFFF"/>
        <SolidColorBrush x:Key="Segment"     Color="#12FFFFFF"/>
        <SolidColorBrush x:Key="SegmentOn"   Color="#2EFFFFFF"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F5F5F7"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#9EA0A6"/>
        <SolidColorBrush x:Key="Accent"      Color="#E0483D"/>
        <SolidColorBrush x:Key="AccentHi"    Color="#FF5A4E"/>
        <SolidColorBrush x:Key="Good"        Color="#4CD964"/>
        <SolidColorBrush x:Key="Warn"        Color="#F5A623"/>
    </Application.Resources>
</Application>
