<Window x:Class="Wpeek.RegionSelector"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" ShowInTaskbar="False"
        Topmost="True" ResizeMode="NoResize" Background="#01000000" Cursor="Cross">
    <Canvas x:Name="Root">
        <TextBlock x:Name="Hint" Foreground="#F0FFFFFF" FontSize="20" FontWeight="SemiBold"
                   Text="Drag to select the recording area   •   Esc to cancel"/>
        <TextBlock x:Name="DimLabel" Foreground="White" FontFamily="Consolas" FontWeight="Bold"
                   FontSize="14" Visibility="Collapsed"/>
    </Canvas>
</Window>
